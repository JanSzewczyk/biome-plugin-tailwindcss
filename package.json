{
  "name": "biome-plugin-tailwindcss",
  "version": "1.0.0",
  "description": "Biome GritQL plugin with Tailwind CSS linting rules",
  "keywords": [
    "biome",
    "biome-plugin",
    "tailwindcss",
    "tailwind",
    "linter",
    "gritql"
  ],
  "homepage": "https://github.com/JanSzewczyk/biome-plugin-tailwindcss#readme",
  "bugs": {
    "url": "https://github.com/JanSzewczyk/biome-plugin-tailwindcss/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JanSzewczyk/biome-plugin-tailwindcss.git"
  },
  "license": "MIT",
  "files": [
    "rules/**/*.grit",
    "presets/*.json",
    "README.md"
  ],
  "scripts": {
    "biome:check": "biome check .",
    "biome:ci": "biome ci --reporter=github",
    "biome:fix": "biome check --write .",
    "biome:format": "biome format .",
    "biome:format:fix": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:lint:fix": "biome lint --write .",
    "test": "node tests/run.mjs"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@szum-tech/semantic-release-config": "^2.3.7",
    "semantic-release": "^25.0.3"
  }
}
